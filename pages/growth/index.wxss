.baby-strip {
  padding: 24rpx 28rpx;
  margin-bottom: 22rpx;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.metric-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: #f3fbf8;
}

.metric-label {
  color: #6e8f83;
  font-size: 24rpx;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.metric-change {
  margin-top: 10rpx;
  color: #2f8e6d;
}

.growth-btn {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

growth-chart {
  display: block;
  margin-bottom: 28rpx;
}

.analysis-block {
  margin: 10rpx 0 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #faf7f2;
}

.analysis-card {
  margin-top: 8rpx;
}

.analysis-text {
  line-height: 1.8;
}

.analysis-sub {
  margin-bottom: 18rpx;
}

.history-row {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2eee9;
  font-size: 24rpx;
}

.sheet-field {
  margin-top: 22rpx;
}

.save-sheet-btn {
  margin-top: 32rpx;
  margin-bottom: 8rpx;
}

.picker-input {
  display: flex;
  align-items: center;
}

.center-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-inline {
  text-align: center;
  padding: 18rpx 0 8rpx;
}

.empty-inline-image {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
}

.empty-inline-title {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-inline-desc {
  margin-top: 8rpx;
  color: #8a8177;
  line-height: 1.7;
}
