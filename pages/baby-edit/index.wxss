.edit-panel {
  padding: 28rpx;
}

.avatar-editor {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.baby-avatar-preview {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #fff4e5;
  box-shadow: 0 12rpx 26rpx rgba(71, 49, 29, 0.08);
  overflow: hidden;
}

.avatar-upload-btn {
  margin-top: 18rpx;
  width: 220rpx;
}

.field {
  margin-top: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  color: #333333;
}

.add-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.add-input {
  flex: 1;
}

.add-chip {
  background: #fff7ee;
  border: 2rpx dashed #ffc979;
  color: #c66c25;
}

.mini-btn {
  width: 148rpx;
  flex-shrink: 0;
}

.save-btn {
  margin-top: 36rpx;
}

.center-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
