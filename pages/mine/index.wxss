.profile-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-width: 0;
  flex: 1;
}

.profile-text {
  min-width: 0;
  flex: 1;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #fff4e5;
  box-shadow: 0 12rpx 26rpx rgba(71, 49, 29, 0.08);
  overflow: hidden;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-edit-icon {
  flex-shrink: 0;
  width: 44rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #fff1dc;
}

.profile-edit-pencil {
  position: relative;
  width: 18rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #c66c25;
  transform: rotate(-32deg);
}

.profile-edit-pencil::before {
  content: '';
  position: absolute;
  left: -8rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 3rpx solid transparent;
  border-bottom: 3rpx solid transparent;
  border-right: 8rpx solid #f6d6b2;
}

.profile-edit-pencil::after {
  content: '';
  position: absolute;
  right: -5rpx;
  top: 0;
  width: 5rpx;
  height: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: #ffb24c;
}

.edit-pill {
  align-self: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffd6a5;
  color: #c66c25;
  background: #fff7ee;
  font-size: 24rpx;
}

.baby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.baby-item-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
  flex: 1;
}

.baby-item-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #fff4e5;
  box-shadow: 0 10rpx 22rpx rgba(71, 49, 29, 0.08);
  overflow: hidden;
  flex-shrink: 0;
}

.baby-item-info {
  min-width: 0;
  flex: 1;
}

.baby-item-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.add-btn {
  margin-top: 24rpx;
}

.family-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 0;
}

.family-entry-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.family-enter-pill {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffd6a5;
  background: #fff7ee;
  color: #c66c25;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.center-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.content-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.content-tile {
  padding: 30rpx;
  border-radius: 26rpx;
  background: #fff4e5;
  text-align: center;
  font-weight: 700;
  color: #a8601a;
}

.setting-row,
.setting-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.profile-sheet {
  max-height: 70vh;
  overflow: hidden;
}

.profile-editor-avatar {
  margin-top: 22rpx;
  text-align: center;
  position: relative;
}

.profile-editor-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  margin: 0 auto 10rpx;
  display: block;
  background: #fff4e5;
}

.avatar-picker-btn {
  margin-top: 16rpx;
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 2rpx solid #ffd7a7;
  background: #fff7ee;
  color: #c66c25;
  font-size: 24rpx;
  text-align: center;
  padding: 0;
}

.avatar-picker-btn::after {
  border: none;
}

.profile-editor-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.profile-save-btn {
  margin-top: 30rpx;
  margin-bottom: 8rpx;
}
