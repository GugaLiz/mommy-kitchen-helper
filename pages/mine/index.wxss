.profile-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #fff4e5;
  box-shadow: 0 12rpx 26rpx rgba(71, 49, 29, 0.08);
  overflow: hidden;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
}

.edit-pill {
  align-self: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffd6a5;
  color: #c66c25;
  background: #fff7ee;
  font-size: 24rpx;
}

.baby-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.baby-item-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.add-btn {
  margin-top: 24rpx;
}

.center-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.content-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.content-tile {
  padding: 30rpx;
  border-radius: 26rpx;
  background: #fff4e5;
  text-align: center;
  font-weight: 700;
  color: #a8601a;
}

.setting-row,
.setting-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.profile-sheet {
  max-height: 70vh;
  overflow: hidden;
}

.profile-editor-avatar {
  margin-top: 22rpx;
  text-align: center;
}

.profile-editor-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  margin: 0 auto 10rpx;
  display: block;
  background: #fff4e5;
}

.profile-editor-tip {
  font-size: 24rpx;
}

.profile-editor-subtip {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.profile-editor-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2eee9;
}

.profile-save-btn {
  margin-top: 30rpx;
  margin-bottom: 8rpx;
}
