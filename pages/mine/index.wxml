<view class="page-shell safe-bottom">
  <view class="panel profile-card" bindtap="openProfileEditor">
    <view class="profile-main">
      <image class="profile-avatar" src="{{user.avatarImage}}" mode="aspectFill" />
      <view class="profile-text">
        <view class="profile-name-row">
          <view class="profile-name">{{user.nickname}}</view>
          <view class="profile-edit-icon">
            <view class="profile-edit-pencil"></view>
          </view>
        </view>
        <view class="muted">{{user.bio || '点击补充个人说明'}}</view>
      </view>
    </view>
  </view>

  <section-card title="我的宝宝">
    <view class="baby-item" wx:for="{{babies}}" wx:key="id" data-id="{{item.id}}" bindtap="editBaby">
      <view class="baby-item-main">
        <image class="baby-item-avatar" src="{{item.avatarImage}}" mode="aspectFill" />
        <view class="baby-item-info">
          <view class="baby-item-title">{{item.nickname}} · {{item.gender}} · {{item.ageText}}</view>
          <view class="muted">过敏：{{item.allergyText}}</view>
          <view class="muted">偏好：{{item.preferenceText}}</view>
        </view>
      </view>
      <view class="edit-pill">编辑</view>
    </view>
    <button class="secondary-btn add-btn center-btn" bindtap="createBaby">+ 添加宝宝</button>
  </section-card>

  <section-card title="我的家庭" subtitle="邀请家人一起管理宝宝记录和周计划">
    <view class="family-entry" bindtap="openFamily">
      <view>
        <view class="family-entry-title">家庭共享</view>
        <view class="muted">邀请爸爸或长辈加入，同步查看宝宝、生长记录和菜单</view>
      </view>
      <view class="family-enter-pill">进入</view>
    </view>
  </section-card>

  <section-card title="设置">
    <view class="setting-row">
      <text>长辈模式</text>
      <switch color="#FFA926" checked="{{user.elderMode}}" bindchange="toggleElderMode" />
    </view>
    <view class="setting-link" bindtap="showCacheNotice">清除缓存</view>
    <view class="setting-link" bindtap="showFeedback">意见反馈</view>
    <view class="setting-link" bindtap="showAbout">关于我们</view>
  </section-card>

  <view class="modal-mask" wx:if="{{showProfileEditor}}" bindtap="closeProfileEditor"></view>

  <view class="floating-sheet profile-sheet" wx:if="{{showProfileEditor}}">
    <view class="row-between">
      <view class="section-title">编辑个人资料</view>
      <view class="close-icon-btn" bindtap="closeProfileEditor">
        <text class="close-icon-text">×</text>
      </view>
    </view>
    <view class="profile-editor-avatar">
      <image class="profile-editor-image" src="{{profileForm.avatarImage}}" mode="aspectFill" />
      <button
        class="avatar-picker-btn"
        open-type="chooseAvatar"
        bindchooseavatar="handleChooseAvatar"
      >
        选择头像
      </button>
    </view>
    <view class="profile-editor-item" bindtap="editNickname">
      <text>昵称</text>
      <text class="muted">{{profileForm.nickname || '点击填写'}}</text>
    </view>
    <view class="profile-editor-item" bindtap="editBio">
      <text>个人说明</text>
      <text class="muted">{{profileForm.bio || '点击填写'}}</text>
    </view>
    <button class="primary-btn center-btn profile-save-btn" bindtap="saveProfile">保存资料</button>
  </view>
</view>
