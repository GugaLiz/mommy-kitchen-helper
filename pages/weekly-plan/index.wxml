<view class="page-shell safe-bottom">
  <view class="panel plan-header">
    <view class="section-title">当前宝宝：{{baby.nickname}} {{baby.ageText}}</view>
    <view class="section-subtitle">一周三餐建议与备菜统筹</view>
    <view class="header-actions">
      <view class="pill-action">本周</view>
      <view class="pill-action" bindtap="refreshPlan">一键换新</view>
      <view class="pill-action" bindtap="showShoppingList">生成备菜清单</view>
    </view>
  </view>

  <view class="panel day-card" wx:for="{{plan}}" wx:key="dayLabel">
    <view class="day-title">{{item.dayLabel}} {{item.shortDate}}</view>
    <view class="meal-line">🥣 早餐：{{item.breakfast.name}}</view>
    <view class="meal-line">☀️ 午餐：{{item.lunch.name}}</view>
    <view class="meal-line">🌙 晚餐：{{item.dinner.name}}</view>
  </view>

  <button class="primary-btn center-btn" bindtap="showShoppingList">一键生成备菜清单</button>

  <view class="modal-mask" wx:if="{{showList}}" bindtap="hideShoppingList"></view>

  <view class="floating-sheet shopping-sheet" wx:if="{{showList}}">
    <view class="row-between">
      <view class="section-title">本周备菜清单</view>
      <view class="close-pill" bindtap="hideShoppingList">关闭</view>
    </view>
    <scroll-view scroll-y class="shopping-scroll">
      <view class="shopping-row" wx:for="{{shoppingList}}" wx:key="ingredient">
        <text>{{item.ingredient}}</text>
        <text class="muted">{{item.summary}}</text>
      </view>
    </scroll-view>
  </view>
</view>
