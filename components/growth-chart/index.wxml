<view class="chart-swiper-shell" wx:if="{{charts.length}}">
  <swiper
    class="chart-swiper"
    current="{{currentIndex}}"
    bindchange="handleSwiperChange"
    indicator-dots="{{false}}"
    duration="260"
  >
    <swiper-item wx:for="{{charts}}" wx:key="title">
      <view class="panel chart-shell">
        <view class="chart-head">
          <view class="chart-title">{{item.title}}（{{item.unit}}）</view>
          <view class="chart-hint">{{index === 0 ? '右滑看体重' : '左滑看身长'}}</view>
        </view>

        <view class="chart-main">
          <view class="y-axis">
            <view
              class="y-tick"
              wx:for="{{item.yTicks}}"
              wx:for-item="tick"
              wx:key="label"
              style="bottom: {{tick.bottom}};"
            >
              {{tick.label}}
            </view>
          </view>

          <view class="chart-area">
            <view
              class="grid-line"
              wx:for="{{item.yTicks}}"
              wx:for-item="tick"
              wx:key="label"
              style="bottom: {{tick.bottom}};"
            ></view>

            <view
              class="band-column"
              wx:for="{{item.bandColumns}}"
              wx:for-item="column"
              wx:key="index"
              style="left: {{column.left}}; bottom: {{column.bottom}}; width: {{column.width}}; height: {{column.height}};"
            ></view>

            <block wx:for="{{item.references}}" wx:key="key" wx:for-item="series">
              <view
                class="line-segment {{series.className}}"
                wx:for="{{series.segments}}"
                wx:for-item="segment"
                wx:key="index"
                style="left: {{segment.left}}; bottom: {{segment.bottom}}; width: {{segment.width}}; transform: {{segment.angle}};"
              ></view>
              <view
                class="curve-tag {{series.className}}"
                style="left: {{series.tagPoint.left}}; bottom: {{series.tagPoint.bottom}};"
              >
                {{series.label}}
              </view>
            </block>

            <view
              class="line-segment actual-line"
              wx:for="{{item.actual.segments}}"
              wx:for-item="segment"
              wx:key="index"
              style="left: {{segment.left}}; bottom: {{segment.bottom}}; width: {{segment.width}}; transform: {{segment.angle}};"
            ></view>

            <view
              class="actual-point"
              wx:for="{{item.actual.points}}"
              wx:for-item="point"
              wx:key="measuredDate"
              style="left: {{point.left}}; bottom: {{point.bottom}};"
            >
              <view class="point-dot {{index === item.actual.points.length - 1 ? 'is-latest' : ''}}"></view>
            </view>

            <view
              class="latest-marker"
              wx:if="{{item.latestMarker}}"
              style="left: {{item.latestMarker.left}};"
            >
              <view class="latest-line"></view>
              <view class="latest-badge">{{item.latestMarker.label}}</view>
            </view>

            <view class="x-axis">
              <view
                class="x-tick"
                wx:for="{{item.xTicks}}"
                wx:for-item="tick"
                wx:key="label"
                style="left: {{tick.left}};"
              >
                {{tick.label}}
              </view>
            </view>
          </view>
        </view>

        <view class="chart-foot muted">
          根据《世卫组织儿童生长标准》计算，当前约位于：{{item.percentileText || percentileText}}
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="chart-dots" wx:if="{{charts.length > 1}}">
    <view class="chart-dot {{currentIndex === 0 ? 'active' : ''}}"></view>
    <view class="chart-dot {{currentIndex === 1 ? 'active' : ''}}"></view>
  </view>
</view>
